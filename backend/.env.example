NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:@localhost:5433/system_tanda
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=120
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
REQUEST_BODY_LIMIT=10kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=5
AUTH_REFRESH_RATE_LIMIT_MAX=20
COOKIE_DOMAIN=
COOKIE_SAME_SITE=strict
JWT_ACCESS_SECRET=replace-this-with-a-32-char-min-access-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_SECRET=replace-this-with-a-32-char-min-refresh-secret
JWT_REFRESH_TTL_SECONDS=2592000
SEED_ADMIN_BRANCH_NAME=Sucursal Principal
SEED_ADMIN_BRANCH_LOCALITATION=Matriz
SEED_ADMIN_NAME=Administrador Principal
SEED_ADMIN_EMAIL=admin@systemtandas.local
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMe12345!
SEED_ADMIN_PHONE=0000000000
SEED_ADMIN_ROLE=admin
SEED_ADMIN_STATUS=active
